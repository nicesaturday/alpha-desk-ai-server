# ============================================================
# Investment — YouTube 감성 지표 (종목명 기준)
# account_id 쿠키: 정수 파싱만 수행 → 1 로 통과
# ============================================================

POST http://localhost:33333/investment/youtube-sentiment
Content-Type: application/json
Cookie: account_id=1

{
  "company": "삼성전자"
}

###

# Investment — YouTube 감성 지표 (log_id 기준)

POST http://localhost:33333/investment/youtube-sentiment
Content-Type: application/json
Cookie: account_id=1

{
  "log_id": 1
}

###

# Investment — 투자 판단 (전체 워크플로우)

POST http://localhost:33333/investment/decision
Content-Type: application/json
Cookie: account_id=1

{
  "query": "삼성전자 지금 어때?"
}

###
